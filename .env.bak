# NexRisk BFF Configuration

PORT=8080
HOST=127.0.0.1
NODE_ENV=development

# NexRisk C++ API on AWS EC2
NEXRISK_API_URL=http://3.21.58.144:8090
NEXRISK_API_TIMEOUT_MS=30000

# Authentication (disabled for development)
AUTH_ENABLED=true
JWT_SECRET=dev-secret-change-in-production

# CORS
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info

# WebSocket
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_CONNECTIONS_PER_USER=5
# WebSocket — points at BFF which proxies to C++ backend port 8081
VITE_WS_URL=ws://localhost:8080

# Internal secret — must match NEXRISK_INTERNAL_SECRET on the C++ server
NEXRISK_INTERNAL_SECRET=dev-internal-secret-change-in-production

# SMTP — AWS SES us-east-2
